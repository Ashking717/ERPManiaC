{
  "name": "erpmania-grocery-erp",
  "version": "4.2.0",
  "description": "Offline Electron ERP app for grocery wholesale and retail billing",
  "main": "main.js",
  "author": "",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "check": "node --check main.js && node --check preload.js && node --check src/main/store.js && node --check src/main/erpService.js && node --check src/main/invoiceTemplate.js && node --check src/main/stockListTemplate.js && node --check src/renderer/app.js",
    "license:keys": "node scripts/generate-license-codes.js",
    "logo:generate": "node scripts/generate-logo.js",
    "ocr:download-eng": "node scripts/download-ocr-eng.js"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "tesseract.js": "^5.1.1"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.erpmania.grocery",
    "productName": "ERPManiaC",
    "files": [
      "main.js",
      "preload.js",
      "src/main/**/*",
      "src/renderer/dist/**/*",
      "assets/**/*",
      "package.json"
    ],
    "mac": {
      "target": "dmg"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/logo/icon.ico",
      "artifactName": "ERPManiaC ${version}.${ext}"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/logo/icon.png"
    }
  }
}
